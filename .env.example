# Copy to `.env.local` and fill in your keys (`.env.local` is gitignored).
#
# Local `vercel dev` loads env via `api/loadEnv.js`: `.env` first, then `.env.local`
# overrides — so keeping secrets only in `.env.local` is fine.
#
# Variable names: serverless routes read unprefixed keys. `VITE_*` names also work
# as fallbacks for the same value.
#
# DEBUG_HAIKU_PROMPT=0  → turn OFF Haiku prompt/reply logs (default: logs ON during /api/parseVideoTitle)

YOUTUBE_API_KEY=<your_youtube_api_key_here>
ANTHROPIC_API_KEY=<your_anthropic_api_key_here>

# Optional aliases (same values if you prefer one file for both Vite + API)
VITE_YOUTUBE_API_KEY=
VITE_ANTHROPIC_API_KEY=
